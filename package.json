{
  "name": "timed-automata-analysis",
  "private": true,
  "version": "3.0.2",
  "type": "module",
  "scripts": {
    "start": "vite",
    "clean": "node -e \"['dist', 'playwright-report', 'test-results'].forEach(p => fs.rmSync(p, { recursive: true, force: true }))\"",
    "build": "tsc && vite build",
    "format": "prettier --write \"./**/*.{css,html,js,cjs,json,md,ts,tsx,yaml}\"",
    "lint": "eslint . --fix --report-unused-disable-directives",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e-ui": "playwright test --ui",
    "e2e-update-snapshots": "playwright test --update-snapshots",
    "deploy": "gh-pages -d dist/timed-automata-analysis",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.0.0",
    "@mui/material": "9.0.0",
    "i18next": "26.0.6",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-http-backend": "3.0.5",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "17.0.4",
    "timed-automata-analyzer": "1.1.0",
    "vis-data": "8.0.3",
    "vis-network": "10.0.2"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "0.3.0",
    "@eslint/js": "9.39.4",
    "@eslint/json": "1.2.0",
    "@playwright/test": "1.59.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/vis": "4.21.27",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "gh-pages": "6.3.0",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "nano-staged": "1.0.2",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.8",
    "vite-plugin-wasm": "3.6.0",
    "vitest": "4.1.4"
  },
  "nano-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --report-unused-disable-directives --max-warnings 0"
    ],
    "*.{css,html,js,cjs,json,md,yaml}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
